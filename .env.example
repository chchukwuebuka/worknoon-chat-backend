# Server
PORT=5000
NODE_ENV=development

# MongoDB - Replace with your MongoDB connection string
# Sign up free at https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/worknoon-chat?retryWrites=true&w=majority

# JWT Secret - Use a strong random string
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
